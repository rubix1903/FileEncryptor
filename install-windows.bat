@echo off
setlocal enabledelayedexpansion

:: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
::  fencrypt  вҖ”  Windows Installer (cmd / PowerShell)
::  installs fencrypt to PATH
:: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

echo.
echo   [36mв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—[0m
echo   [36mв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ[0m
echo   [36mв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   [0m
echo   [36mв–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—  в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв•җв•қ    в–Ҳв–Ҳв•‘   [0m
echo   [36mв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘        в–Ҳв–Ҳв•‘   [0m
echo   [36mв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ        в•ҡв•җв•қ   [0m
echo.
echo   [33m  FileEncrypt v1.0.0 вҖ” Windows Installer[0m
echo     в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo.

set INSTALL_DIR=%ProgramFiles%\fencrypt
set BUILD_DIR=%~dp0_build_release

:: Step 1 вҖ” Check cmake
echo [36m[1/4] Checking dependencies...[0m
where cmake >nul 2>&1
if %errorlevel% neq 0 (
    echo [31m[ERROR][0m cmake not found.
    echo   Install CMake from: https://cmake.org/download/
    echo   Ensure you tick "Add CMake to system PATH" during install.
    exit /b 1
)
where cl >nul 2>&1
if %errorlevel% neq 0 (
    where g++ >nul 2>&1
    if !errorlevel! neq 0 (
        echo [31m[ERROR][0m No C++ compiler found.
        echo   Install Visual Studio Build Tools: https://aka.ms/vs/buildtools
        echo   Or install MinGW-w64 via: https://www.mingw-w64.org/
        exit /b 1
    )
)
echo   [32mвң” cmake and C++ compiler found[0m

:: Step 2 вҖ” Build
echo [36m[2/4] Building release binary...[0m
if not exist "%BUILD_DIR%" mkdir "%BUILD_DIR%"
cmake -S "%~dp0" -B "%BUILD_DIR%" -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX="%INSTALL_DIR%" >nul
cmake --build "%BUILD_DIR%" --config Release
if %errorlevel% neq 0 (
    echo [31m[ERROR][0m Build failed. Check compiler output above.
    exit /b 1
)
echo   [32mвң” Build successful[0m

:: Step 3 вҖ” Install
echo [36m[3/4] Installing to %INSTALL_DIR%...[0m
if not exist "%INSTALL_DIR%" mkdir "%INSTALL_DIR%"
cmake --install "%BUILD_DIR%" --config Release >nul
echo   [32mвң” Installed to %INSTALL_DIR%\fencrypt.exe[0m

:: Step 4 вҖ” Add to PATH via registry
echo [36m[4/4] Adding to system PATH...[0m
setx PATH "%INSTALL_DIR%;%PATH%" /M >nul 2>&1
if %errorlevel% neq 0 (
    echo   [33mвҡ  Could not update system PATH automatically.[0m
    echo     Add manually: %INSTALL_DIR%
) else (
    echo   [32mвң” Added %INSTALL_DIR% to system PATH[0m
)

echo.
echo   [32mInstallation complete![0m
echo     в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo     Open a NEW terminal and run:
echo       fencrypt --help
echo       fencrypt encrypt aes myfile.txt myfile.enc
echo.
pause
